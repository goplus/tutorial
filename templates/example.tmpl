<!DOCTYPE html>
<html lang="{{.Lang}}">
  <head>
    <meta charset="utf-8">
    <title>{{t .Lang "site_title"}}: {{translateTitle .Lang .Title}}</title>
    <link rel="icon" href="/favicon.svg" />
    <meta name="viewport" content="initial-scale=1.0,width=device-width,user-scalable=no"></meta>
    <link rel=stylesheet href="/site.css">
    <script data-widgets="header,footer,code" src="https://xgo.dev/widgets/loader.js"></script>
  </head>
  <script>
      onkeydown = (e) => {
          {{if .Prev}}if (e.key == "ArrowLeft") {
              window.location.href = '{{langPrefix .Lang}}{{.Prev.Path}}';
          }{{end}}
          {{if .Next}}if (e.key == "ArrowRight") {
              window.location.href = '{{langPrefix .Lang}}{{.Next.Path}}';
          }{{end}}
      }
  </script>
  <body>
    {{ template "header" }}
    <main class="main example" id="{{.Path}}">
      <div class="top-bar">
        <ul class="breadcrumb">
          <li class="breadcrumb-link-item"><a href="https://xgo.dev">XGo</a></li>
          <li class="breadcrumb-link-item"><a href="{{langPrefix .Lang}}/">{{t .Lang "breadcrumb_tutorials"}}</a></li>
          <li class="breadcrumb-current-item">{{translateTitle .Lang .Title}}</li>
        </ul>
        <div class="lang-switcher">
          <button class="lang-switcher-btn" aria-label="{{t .Lang "lang_switcher_label"}}">
            <svg class="lang-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
            <span>{{currentLangName .Lang}}</span>
            <svg class="lang-arrow" viewBox="0 0 10 6" width="10" height="6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="lang-menu">
            {{range allLangs}}
            <a href="{{if eq .Code "en"}}{{$.Path}}{{else}}/{{.Code}}{{$.Path}}{{end}}" class="lang-menu-item{{if eq .Code $.Lang}} active{{end}}">{{.Name}}</a>
            {{end}}
          </div>
        </div>
      </div>
      <div class="text-wrapper">
        <h2>{{translateTitle .Lang .Title}}</h2>
        {{if .Files}}{{else}}
          <p>{{t .Lang "no_content_before"}}<a href="https://github.com/goplus/tutorial/tree/main/{{.Name}}">{{t .Lang "no_content_link"}}</a>{{t .Lang "no_content_after"}}</p>
        {{end}}
        {{range .Files}}
          {{if .HeadDoc}}
          <div class="docs">
            {{range .HeadDoc}}
              {{.DocsRendered}}
            {{end}}
          </div>
          {{end}}
          {{if .Code}}
          <xgo-code half-code language="{{.Lang}}">{{range .Code}}{{if .DocsRendered}}<xgo-code-doc>{{.DocsRendered}}</xgo-code-doc>{{end}}{{.CodeRendered}}{{end}}</xgo-code>
          {{end}}
          {{if .TailDoc}}
          <div class="docs">
            {{range .TailDoc}}
              {{.DocsRendered}}
            {{end}}
          </div>
          {{end}}
        {{end}}
        {{if .Next}}
        <p class="next">
          {{t .Lang "next_example"}} <a href="{{langPrefix .Lang}}{{.Next.Path}}">{{translateTitle .Lang .Next.Title}}</a>
        </p>
        {{end}}
      </div>
    </main>
    {{ template "footer" }}
    <script src="./clipboard.min.js"></script>
    <script>
    new ClipboardJS('.copy')
    document.querySelector('.lang-switcher-btn').addEventListener('click', function(e) {
      e.stopPropagation();
      this.parentElement.classList.toggle('open');
    });
    document.addEventListener('click', function() {
      document.querySelector('.lang-switcher').classList.remove('open');
    });
    </script>
  </body>
</html>
